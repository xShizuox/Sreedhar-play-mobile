# Server Port (Optional)
PORT=3000

# JWT Secret Key
JWT_SECRET=your-secure-secret-key-premium-vibes

# Database URL for Postgres (e.g., from Neon or Supabase)
DATABASE_URL=postgres://your_user:your_password@your_host/your_db?sslmode=require

# Cloudinary URL for media storage (Copy directly from your Cloudinary console)
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name
